# ==========================================
# 💎 AXIOM STUDIO: ENVIRONMENT CONFIGURATION
# ==========================================

# --- AI ORCHESTRATOR (GEMINI) ---
# Add up to 5 Gemini API keys for round-robin rotation
GEMINI_KEY_1=your_gemini_key_1
GEMINI_KEY_2=your_gemini_key_2
GEMINI_KEY_3=your_gemini_key_3
GEMINI_KEY_4=your_gemini_key_4
GEMINI_KEY_5=your_gemini_key_5

# --- FIREBASE (FRONTEND & BACKEND) ---
# Obtain these from your Firebase Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# --- FIREBASE ADMIN (BACKEND ONLY) ---
# Path to your Firebase serviceAccountKey.json file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# --- SYSTEM ---
PORT=8080
HOST=0.0.0.0
